if os.name == 'nt':
    import winsound
else:
    winsound = None


BLACK = "#000000"
GREEN = "#00FF41"
RED = "#FF003C"
YELLOW = "#FDF000"
CYAN = "#00F3FF"
WHITE = "#FFFFFF"


istatistikler = {
    "toplam_denenen": 0,
    "gecersiz": 0,
    "engel": 0,
    "hata": 0
}


KILIT_SIFRESI = "CEYTX"


